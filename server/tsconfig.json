{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "server.ts",
    "../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}